<% content_for :head do %>
  <%= stylesheet_link_tag "admin", "data-turbo-track": "reload" %>
<% end %>

<div class="grid-bg"></div>

<div class="login-wrap">
  <div class="login-box">

    <div class="login-logo">
      <div class="logo-icon">✚</div>
      <div>
        <span class="logo-main">UDA</span>
        <span class="logo-sub">Admin Portal</span>
      </div>
    </div>

    <h2 class="login-title">Welcome Back</h2>
    <p class="login-sub">Sign in to manage UDA registrations & activities</p>

    <% if flash[:alert] %>
      <div class="flash-error">⚠ <%= flash[:alert] %></div>
    <% end %>
    <% if flash[:notice] %>
      <div class="flash-success">✅ <%= flash[:notice] %></div>
    <% end %>

    <%= form_with url: admin_login_path, method: :post, local: true do |f| %>
      <div class="form-group">
        <label>Email Address</label>
        <%= f.email_field :email, placeholder: "admin@udapune.org", required: true %>
      </div>
      <div class="form-group">
        <label>Password</label>
        <%= f.password_field :password, placeholder: "••••••••", required: true %>
      </div>
      <%= f.submit "Sign In →", class: "login-btn" %>
    <% end %>

    <div class="login-footer">
      <%= link_to "← Back to UDA Website", root_path, data: { turbo: false } %>
    </div>

  </div>
</div>
