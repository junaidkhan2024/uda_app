<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>UDA – United Doctors Association, Pune</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400&family=Cormorant+Garamond:wght@300;400;500;600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
<style>
  :root {
    --navy: #0A1628;
    --navy-mid: #112240;
    --navy-light: #1a3560;
    --gold: #C9A84C;
    --gold-light: #e8c97a;
    --gold-pale: #f5e9c8;
    --cream: #FAF7F0;
    --white: #ffffff;
    --text-muted: #8a9bb5;
    --shadow: 0 20px 60px rgba(0,0,0,0.3);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Lato', sans-serif;
    background: var(--navy);
    color: var(--white);
    overflow-x: hidden;
  }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--navy); }
  ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 3px; }

  /* ── NAV ── */
  nav {
    position: fixed; top:0; width:100%; z-index:1000;
    background: rgba(10,22,40,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(201,168,76,0.25);
    padding: 0 40px;
    display: flex; align-items: center; justify-content: space-between;
    height: 72px;
    transition: all 0.3s;
  }
  nav.scrolled { background: rgba(10,22,40,0.99); box-shadow: 0 4px 30px rgba(0,0,0,0.4); }

  .nav-logo {
    display: flex; align-items: center; gap: 14px;
    text-decoration: none;
  }
  .nav-logo .logo-icon {
    width: 42px; height: 42px;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; font-weight: 900;
    color: var(--navy);
    font-family: 'Playfair Display', serif;
    box-shadow: 0 0 20px rgba(201,168,76,0.4);
  }
  .nav-logo .logo-text { line-height: 1.2; }
  .nav-logo .logo-text span { display: block; }
  .nav-logo .logo-text .main { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 700; color: var(--gold); }
  .nav-logo .logo-text .sub { font-size: 10px; color: var(--text-muted); letter-spacing: 2px; text-transform: uppercase; }

  .nav-links { display: flex; gap: 8px; list-style: none; }
  .nav-links a {
    color: var(--text-muted); text-decoration: none;
    font-size: 13px; letter-spacing: 1px; text-transform: uppercase;
    padding: 8px 16px; border-radius: 6px;
    transition: all 0.25s;
    font-weight: 700;
  }
  .nav-links a:hover, .nav-links a.active { color: var(--gold); background: rgba(201,168,76,0.1); }

  .nav-cta {
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    color: var(--navy) !important;
    border-radius: 8px !important;
    font-weight: 700 !important;
  }
  .nav-cta:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(201,168,76,0.4); background: var(--gold-light) !important; }

  /* ── HERO ── */
  #home {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    background: var(--navy);
  }

  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 70% 50%, rgba(201,168,76,0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 20% 80%, rgba(26,53,96,0.6) 0%, transparent 50%),
      linear-gradient(160deg, var(--navy) 0%, var(--navy-mid) 50%, #0d1e3d 100%);
  }

  .hero-grid {
    position: absolute; inset: 0; opacity: 0.04;
    background-image:
      linear-gradient(var(--gold) 1px, transparent 1px),
      linear-gradient(90deg, var(--gold) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .hero-cross {
    position: absolute; right: 8%; top: 50%; transform: translateY(-50%);
    opacity: 0.06; font-size: 320px; font-weight: 900;
    color: var(--gold); line-height: 1;
    font-family: 'Playfair Display', serif;
    user-select: none;
    animation: pulse-slow 4s ease-in-out infinite;
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.06; transform: translateY(-50%) scale(1); }
    50% { opacity: 0.1; transform: translateY(-50%) scale(1.02); }
  }

  .hero-content {
    position: relative; z-index: 2;
    max-width: 750px; padding: 0 40px;
    text-align: center;
  }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.3);
    padding: 6px 18px; border-radius: 30px;
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--gold); margin-bottom: 28px;
    animation: fadeInDown 0.8s ease both;
  }
  .hero-badge::before { content: '✦'; font-size: 8px; }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(44px, 7vw, 80px);
    font-weight: 900; line-height: 1.05;
    margin-bottom: 10px;
    animation: fadeInUp 0.8s ease 0.2s both;
  }
  .hero-title .uda { color: var(--gold); }

  .hero-full-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(16px, 2.5vw, 22px);
    color: var(--gold-pale); font-weight: 300;
    letter-spacing: 3px; text-transform: uppercase;
    margin-bottom: 20px;
    animation: fadeInUp 0.8s ease 0.35s both;
  }

  .hero-divider {
    width: 80px; height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 20px auto 24px;
    animation: fadeInUp 0.8s ease 0.4s both;
  }

  .hero-tagline {
    font-size: clamp(15px, 2vw, 19px);
    color: var(--text-muted); font-weight: 300;
    line-height: 1.6; margin-bottom: 40px;
    font-style: italic;
    animation: fadeInUp 0.8s ease 0.5s both;
  }

  .hero-btns {
    display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;
    animation: fadeInUp 0.8s ease 0.65s both;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    color: var(--navy); padding: 14px 34px; border-radius: 8px;
    font-weight: 700; font-size: 14px; letter-spacing: 1.5px;
    text-transform: uppercase; text-decoration: none;
    transition: all 0.3s; border: none; cursor: pointer;
    box-shadow: 0 8px 30px rgba(201,168,76,0.35);
  }
  .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 14px 40px rgba(201,168,76,0.5); }

  .btn-outline {
    background: transparent;
    color: var(--gold); padding: 14px 34px; border-radius: 8px;
    font-weight: 700; font-size: 14px; letter-spacing: 1.5px;
    text-transform: uppercase; text-decoration: none;
    transition: all 0.3s; cursor: pointer;
    border: 1px solid rgba(201,168,76,0.5);
  }
  .btn-outline:hover { background: rgba(201,168,76,0.1); transform: translateY(-3px); border-color: var(--gold); }

  .hero-stats {
    position: absolute; bottom: 40px; left: 0; right: 0;
    display: flex; justify-content: center; gap: 60px;
    animation: fadeInUp 0.8s ease 0.8s both;
  }
  .stat { text-align: center; }
  .stat-num { font-family: 'Playfair Display', serif; font-size: 36px; font-weight: 700; color: var(--gold); line-height: 1; }
  .stat-label { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); margin-top: 4px; }

  @keyframes fadeInDown { from { opacity:0; transform: translateY(-20px); } to { opacity:1; transform: translateY(0); } }
  @keyframes fadeInUp { from { opacity:0; transform: translateY(30px); } to { opacity:1; transform: translateY(0); } }

  /* ── SECTION BASE ── */
  section { padding: 100px 40px; }
  .section-tag {
    font-size: 11px; letter-spacing: 4px; text-transform: uppercase;
    color: var(--gold); display: flex; align-items: center; gap: 12px;
    margin-bottom: 14px;
  }
  .section-tag::before, .section-tag::after {
    content: ''; flex: 1; max-width: 40px; height: 1px; background: var(--gold); opacity: 0.5;
  }
  .section-tag::before { display: none; }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700; line-height: 1.1; margin-bottom: 16px;
  }
  .section-subtitle {
    color: var(--text-muted); font-size: 16px; line-height: 1.7; max-width: 580px;
  }
  .gold-line {
    width: 60px; height: 3px; background: linear-gradient(90deg, var(--gold), var(--gold-light));
    margin: 20px 0; border-radius: 2px;
  }

  /* ── ABOUT ── */
  #about { background: var(--navy-mid); }
  .about-inner {
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
  }
  .about-text p {
    color: #b8c7e0; line-height: 1.9; margin-bottom: 16px; font-size: 15px;
  }
  .about-features { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 30px; }
  .feature-item {
    background: rgba(201,168,76,0.07); border: 1px solid rgba(201,168,76,0.15);
    border-radius: 10px; padding: 18px;
    transition: all 0.3s;
  }
  .feature-item:hover { background: rgba(201,168,76,0.12); transform: translateY(-3px); }
  .feature-icon { font-size: 28px; margin-bottom: 8px; }
  .feature-title { font-size: 13px; font-weight: 700; color: var(--gold); letter-spacing: 1px; margin-bottom: 4px; }
  .feature-desc { font-size: 12px; color: var(--text-muted); line-height: 1.5; }

  .about-visual {
    position: relative;
  }
  .about-card {
    background: linear-gradient(135deg, var(--navy-light), var(--navy));
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 20px; padding: 40px;
    position: relative; overflow: hidden;
  }
  .about-card::before {
    content: ''; position: absolute; top: -40px; right: -40px;
    width: 150px; height: 150px;
    background: radial-gradient(circle, rgba(201,168,76,0.15) 0%, transparent 70%);
    border-radius: 50%;
  }
  .mission-item { margin-bottom: 28px; }
  .mission-label { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
  .mission-text { font-family: 'Cormorant Garamond', serif; font-size: 19px; line-height: 1.6; color: var(--cream); font-style: italic; }
  .values-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 20px; }
  .value-chip {
    background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2);
    border-radius: 6px; padding: 8px 14px;
    font-size: 12px; color: var(--gold-pale); text-align: center; font-weight: 700; letter-spacing: 1px;
  }

  /* ── LEADERSHIP ── */
  #leadership { background: var(--navy); }
  .leadership-inner { max-width: 1200px; margin: 0 auto; }
  .leaders-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 60px;
  }
  .leader-card {
    background: linear-gradient(160deg, var(--navy-mid), var(--navy));
    border: 1px solid rgba(201,168,76,0.2); border-radius: 20px;
    padding: 40px 30px; text-align: center;
    transition: all 0.4s; position: relative; overflow: hidden;
  }
  .leader-card::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(201,168,76,0.05), transparent);
    opacity: 0; transition: opacity 0.4s;
  }
  .leader-card:hover { transform: translateY(-10px); border-color: rgba(201,168,76,0.5); box-shadow: 0 30px 60px rgba(0,0,0,0.4), 0 0 40px rgba(201,168,76,0.1); }
  .leader-card:hover::before { opacity: 1; }
  .leader-card.featured { border-color: rgba(201,168,76,0.4); }
  .leader-card.featured .leader-role-badge { background: linear-gradient(135deg, var(--gold), var(--gold-light)); color: var(--navy); }

  .leader-photo-wrap {
    position: relative; display: inline-block; margin-bottom: 24px;
  }
  .leader-photo {
    width: 110px; height: 110px; border-radius: 50%;
    border: 3px solid rgba(201,168,76,0.3);
    background: linear-gradient(135deg, var(--navy-light), var(--navy-mid));
    display: flex; align-items: center; justify-content: center;
    font-size: 42px; margin: 0 auto;
    position: relative; overflow: hidden;
  }
  .leader-photo-ring {
    position: absolute; inset: -6px; border-radius: 50%;
    border: 1px solid rgba(201,168,76,0.2);
    border-top-color: var(--gold);
    animation: spin 8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .leader-role-badge {
    display: inline-block; margin-bottom: 12px;
    background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.3);
    color: var(--gold); font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
    padding: 4px 14px; border-radius: 20px; font-weight: 700;
  }
  .leader-name { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; margin-bottom: 4px; }
  .leader-qual { font-size: 12px; color: var(--gold); margin-bottom: 12px; font-weight: 700; letter-spacing: 1px; }
  .leader-bio { font-size: 13px; color: var(--text-muted); line-height: 1.7; }

  /* ── ACTIVITIES ── */
  #activities { background: var(--navy-mid); }
  .activities-inner { max-width: 1200px; margin: 0 auto; }
  .activities-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 60px;
  }
  .activity-card {
    background: var(--navy); border: 1px solid rgba(201,168,76,0.15);
    border-radius: 16px; overflow: hidden;
    transition: all 0.4s; cursor: pointer;
  }
  .activity-card:hover { transform: translateY(-8px); border-color: rgba(201,168,76,0.4); box-shadow: 0 25px 50px rgba(0,0,0,0.4); }

  .activity-img {
    height: 180px; display: flex; align-items: center; justify-content: center;
    font-size: 56px; position: relative; overflow: hidden;
  }
  .activity-img::before {
    content: ''; position: absolute; inset: 0;
    transition: opacity 0.3s;
  }
  .act-1 .activity-img { background: linear-gradient(135deg, #1a3a6b, #0d2244); }
  .act-1 .activity-img::before { background: radial-gradient(circle at 60% 40%, rgba(201,168,76,0.2), transparent); }
  .act-2 .activity-img { background: linear-gradient(135deg, #3a1a1a, #5c1a1a); }
  .act-2 .activity-img::before { background: radial-gradient(circle at 40% 60%, rgba(220,60,60,0.2), transparent); }
  .act-3 .activity-img { background: linear-gradient(135deg, #1a3a2a, #0d3320); }
  .act-3 .activity-img::before { background: radial-gradient(circle at 50% 50%, rgba(60,180,90,0.2), transparent); }
  .act-4 .activity-img { background: linear-gradient(135deg, #3a2a1a, #5c3a00); }
  .act-4 .activity-img::before { background: radial-gradient(circle at 60% 40%, rgba(201,140,40,0.25), transparent); }
  .act-5 .activity-img { background: linear-gradient(135deg, #1a2a3a, #0d2033); }
  .act-5 .activity-img::before { background: radial-gradient(circle at 40% 60%, rgba(60,120,220,0.2), transparent); }
  .act-6 .activity-img { background: linear-gradient(135deg, #2a1a3a, #1a0d44); }
  .act-6 .activity-img::before { background: radial-gradient(circle at 50% 40%, rgba(140,60,220,0.2), transparent); }

  .activity-body { padding: 24px; }
  .activity-date { font-size: 11px; letter-spacing: 2px; color: var(--gold); text-transform: uppercase; margin-bottom: 8px; }
  .activity-title { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 600; margin-bottom: 10px; }
  .activity-desc { font-size: 13px; color: var(--text-muted); line-height: 1.6; }
  .activity-tag {
    display: inline-block; margin-top: 14px;
    background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2);
    color: var(--gold); font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
    padding: 3px 12px; border-radius: 20px;
  }

  /* ── REGISTRATION ── */
  #register { background: var(--navy); }
  .register-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1.4fr; gap: 80px; align-items: start;
  }
  .register-info { padding-top: 20px; }
  .register-info p { color: var(--text-muted); font-size: 15px; line-height: 1.8; margin-bottom: 24px; }
  .benefit-item { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 18px; }
  .benefit-icon { font-size: 22px; margin-top: 2px; flex-shrink: 0; }
  .benefit-text strong { display: block; font-size: 13px; font-weight: 700; color: var(--gold-pale); margin-bottom: 2px; }
  .benefit-text span { font-size: 12px; color: var(--text-muted); }

  .register-form-wrap {
    background: linear-gradient(160deg, var(--navy-mid), var(--navy));
    border: 1px solid rgba(201,168,76,0.2); border-radius: 24px;
    padding: 44px;
  }
  .form-title { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 700; margin-bottom: 6px; }
  .form-sub { font-size: 13px; color: var(--text-muted); margin-bottom: 32px; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group { margin-bottom: 18px; }
  .form-group label { display: block; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; font-weight: 700; }
  .form-group input, .form-group select, .form-group textarea {
    width: 100%; background: rgba(255,255,255,0.04);
    border: 1px solid rgba(201,168,76,0.2); border-radius: 8px;
    padding: 12px 16px; color: var(--white); font-size: 14px; font-family: 'Lato', sans-serif;
    transition: all 0.3s; outline: none;
    -webkit-appearance: none;
  }
  .form-group input::placeholder, .form-group textarea::placeholder { color: rgba(255,255,255,0.2); }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
    border-color: var(--gold); background: rgba(201,168,76,0.05);
    box-shadow: 0 0 0 3px rgba(201,168,76,0.1);
  }
  .form-group select option { background: var(--navy-mid); color: var(--white); }
  .form-group textarea { height: 90px; resize: vertical; }
  .file-input-wrap {
    border: 1px dashed rgba(201,168,76,0.3); border-radius: 8px;
    padding: 20px; text-align: center; cursor: pointer;
    transition: all 0.3s;
  }
  .file-input-wrap:hover { border-color: var(--gold); background: rgba(201,168,76,0.05); }
  .file-input-wrap input[type=file] { display: none; }
  .file-input-wrap .file-label { font-size: 13px; color: var(--text-muted); cursor: pointer; }
  .file-input-wrap .file-label strong { color: var(--gold); }

  .submit-btn {
    width: 100%; padding: 16px; border-radius: 10px; border: none;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    color: var(--navy); font-size: 15px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase; cursor: pointer;
    transition: all 0.3s; margin-top: 8px;
    box-shadow: 0 8px 30px rgba(201,168,76,0.3);
  }
  .submit-btn:hover { transform: translateY(-2px); box-shadow: 0 14px 40px rgba(201,168,76,0.5); }

  .success-msg {
    display: none; text-align: center; padding: 24px;
    background: rgba(60,180,90,0.1); border: 1px solid rgba(60,180,90,0.3);
    border-radius: 12px; margin-top: 16px;
  }
  .success-msg.show { display: block; animation: fadeInUp 0.5s ease; }
  .success-msg .check { font-size: 40px; margin-bottom: 10px; }
  .success-msg p { color: #7ae0a0; font-size: 15px; }

  /* ── CONTACT ── */
  #contact { background: var(--navy-mid); padding: 80px 40px 0; }
  .contact-inner { max-width: 1200px; margin: 0 auto; }
  .contact-grid {
    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 60px;
    padding-bottom: 60px; border-bottom: 1px solid rgba(201,168,76,0.15);
  }
  .contact-brand .logo-big {
    font-family: 'Playfair Display', serif; font-size: 36px; font-weight: 900;
    color: var(--gold); margin-bottom: 6px;
  }
  .contact-brand .logo-sub { font-size: 12px; letter-spacing: 3px; color: var(--text-muted); text-transform: uppercase; margin-bottom: 20px; }
  .contact-brand p { font-size: 14px; color: var(--text-muted); line-height: 1.7; max-width: 300px; }

  .contact-col h4 { font-family: 'Playfair Display', serif; font-size: 16px; margin-bottom: 20px; color: var(--gold-pale); }
  .contact-col ul { list-style: none; }
  .contact-col ul li { margin-bottom: 12px; }
  .contact-col ul li a { color: var(--text-muted); text-decoration: none; font-size: 14px; transition: color 0.2s; }
  .contact-col ul li a:hover { color: var(--gold); }

  .contact-info-item { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; }
  .contact-info-item .ci-icon { font-size: 18px; flex-shrink: 0; margin-top: 2px; }
  .contact-info-item .ci-text { font-size: 13px; color: var(--text-muted); line-height: 1.5; }

  .social-row { display: flex; gap: 12px; margin-top: 20px; }
  .social-btn {
    width: 38px; height: 38px; border-radius: 8px;
    background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; transition: all 0.3s; text-decoration: none; cursor: pointer;
  }
  .social-btn:hover { background: rgba(201,168,76,0.2); transform: translateY(-3px); }

  .footer-bottom {
    padding: 24px 0; display: flex; align-items: center; justify-content: space-between;
    max-width: 1200px; margin: 0 auto;
  }
  .footer-bottom p { font-size: 13px; color: var(--text-muted); }
  .footer-bottom span { color: var(--gold); }

  /* ── BACK TO TOP ── */
  #back-top {
    position: fixed; bottom: 30px; right: 30px; z-index: 999;
    width: 44px; height: 44px; border-radius: 10px;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    color: var(--navy); border: none; cursor: pointer;
    font-size: 18px; display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 25px rgba(201,168,76,0.4);
    opacity: 0; transform: translateY(20px);
    transition: all 0.3s;
  }
  #back-top.visible { opacity: 1; transform: translateY(0); }
  #back-top:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(201,168,76,0.5); }

  /* ── SCROLL REVEAL ── */
  .reveal { opacity: 0; transform: translateY(40px); transition: all 0.7s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .about-inner, .register-inner { grid-template-columns: 1fr; gap: 50px; }
    .leaders-grid, .activities-grid { grid-template-columns: repeat(2, 1fr); }
    .contact-grid { grid-template-columns: 1fr 1fr; }
    .contact-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 768px) {
    nav { padding: 0 20px; }
    .nav-links { display: none; }
    section { padding: 70px 20px; }
    .hero-stats { gap: 30px; }
    .stat-num { font-size: 28px; }
    .leaders-grid, .activities-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .contact-grid { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; gap: 10px; text-align: center; }
  }
</style>
</head>
